{
  "name": "@codemcp/workflows-server",
  "version": "6.6.3",
  "description": "MCP server for responsible-vibe development workflows - provides structured workflow guidance",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ade-workflows-server": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "skill/**/*",
    "resources/**/*"
  ],
  "scripts": {
    "build": "tsup && pnpm copy-resources",
    "copy-resources": "rm -rf resources && cp -r ../core/resources .",
    "build:tsc": "tsc -p tsconfig.build.json",
    "clean:build": "rimraf ./dist",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@codemcp/workflows-core": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  }
}
